{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist-api",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "strict": false,
    "declaration": true,
    "composite": true
  },
  "include": ["api/**/*.ts", "scripts/**/*.ts"]
}

